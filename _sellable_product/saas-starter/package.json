    "lucide-react": "^0.363.0",
    "next": "14.2.0",
    "next-auth": "^4.24.7",
    "next-themes": "^0.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.1",
    "resend": "^3.2.0",
    "stripe": "^15.1.0",
    "tailwind-merge": "^2.2.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.0",
    "postcss": "^8.4.38",
    "prisma": "^5.12.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.3"
  },
