{
  "name": "evo-anything",
  "version": "0.1.0",
  "description": "Git-based evolutionary algorithm design engine. Evolves code via LLM-driven mutation, crossover, and reflection on any git repository.",
  "keywords": [
    "ai",
    "evolutionary-algorithm",
    "llm",
    "code-optimization",
    "openclaw"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DataLab-atom/Evo-anything.git"
  },
  "engines": {
    "node": ">=16"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "bin": {
    "evo-anything": "scripts/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "openclaw.plugin.json",
    "dist/",
    "plugin/",
    "scripts/",
    "README.md",
    "README_EN.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@openclaw/lobster": "^2026.3.13",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
